# Copy to `.env` in the repo root and fill in values.
# Never commit `.env` (it is listed in `.gitignore`).

# Required for live section review (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional: model for `run_context_fidelity_review` / numeric-consistency skill
OPENAI_REVIEW_MODEL=gpt-4o

# Optional: workspace default for CLI tools
# WORKSPACE_ROOT=./workspace
